# ── Database ────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/geuphalttaen?characterEncoding=UTF-8&serverTimezone=Asia/Seoul
DB_USERNAME=geuphalttaen
DB_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# 최소 32자 이상의 무작위 문자열
JWT_SECRET=change-me-this-is-a-very-long-secret-key

# ── Open Data ────────────────────────────────────────────────────────────────
# https://www.data.go.kr 에서 발급
OPENDATA_TOILET_API_KEY=

# ── Cloudflare R2 ────────────────────────────────────────────────────────────
# Cloudflare 대시보드 > R2 > API 토큰에서 발급
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_NAME=
# 버킷의 퍼블릭 URL (예: https://pub-xxxx.r2.dev)
CF_R2_PUBLIC_URL=
# 업로드 기본 폴더 prefix (기본값: toilet-images)
CF_R2_FOLDER=toilet-images
